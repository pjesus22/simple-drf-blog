# Core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1   # comma-separated, no spaces

# Database
DATABASE_URL=mysql://user:password@db:3306/dbname
MARIADB_DATABASE=dbname
MARIADB_USER=user
MARIADB_PASSWORD=password
MARIADB_ROOT_PASSWORD=change-me-root-password

# Storage backend: local | s3 | gcs
MEDIA_STORAGE_BACKEND=local

# S3 (required when MEDIA_STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# GCS (required when MEDIA_STORAGE_BACKEND=gcs)
GS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=   # absolute path to service-account JSON inside the container

# Security
SECURE_SSL_REDIRECT=True

# Monitoring (optional)
SENTRY_DSN=https://example.ingest.sentry.io/example
ENVIRONMENT=production

# Metadata
API_VERSION=1.0
